FROM debian:12.7

WORKDIR /benchmarks

COPY . .

RUN apt update && apt install -y --no-install-recommends \
    sudo \
    tcpdump \
    curl \
    wget \
    unzip \
    samtools \
    minimap2 \
    bcftools \
    python3-pip \
    vim \
    ffmpeg unrtf imagemagick libarchive-tools libncurses5-dev libncursesw5-dev zstd liblzma-dev libbz2-dev zip unzip nodejs tcpdump \
    git \
    gpg

RUN pip3 install --break-system-packages \
    scikit-learn \
    kaggle

RUN useradd -m user && \
    echo "user ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers && \
    chown -R user:user /benchmarks

RUN cd /benchmarks && \
    for benchmark in */; do \
        if [ -d "$benchmark" ] && [[ "$benchmark" != "infrastructure" && "$benchmark" != "temp" ]]; then \
            echo "Running benchmark: $benchmark"; \
            cd "$benchmark" && ./main.sh --min || echo "Failed to run $benchmark"; \
        fi; \
    done

ENTRYPOINT ["bash"]
